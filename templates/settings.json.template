{
  "_comment": "Drop-in starter for ~/.claude/settings.json. Deep-merge with existing config — /team-setup:team-curate handles this safely. Edit deny/ask patterns to match your environment.",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/*.kdbx)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.netrc)",
      "Read(**/.pgpass)",
      "Read(**/gcloud/**/*.json)",
      "Read(**/kubeconfig)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit --no-gpg-sign*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Write(**/.env*)",
      "Write(**/CLAUDE.md)",
      "Edit(**/.gitignore)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-launcher.sh"
  }
}
